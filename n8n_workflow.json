      "position": [
        380,
        240
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO bookings (id, customer_name, customer_phone, customer_telegram, booking_date, booking_time, pickup_address, destination_address, estimated_distance, price, status) VALUES ('{{ $json.body.bookingId || $uuid }}', '{{ $json.body.name }}', '{{ $json.body.phone }}', '{{ $json.body.telegram }}', '{{ $json.body.date }}', '{{ $json.body.time }}', '{{ $json.body.pickup_address }}', '{{ $json.body.destination_address }}', {{ $json.body.estimated_distance }}, {{ $json.body.price }}, 'pending');"
      },
      "id": "8c59f2a9-7c8d-4f11-b8d9-2c709abdb101",
      "name": "SQL: Save Pending Booking",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1.1,
      "position": [
        600,
        240
      ]
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "=🚖 NEW RIDE REQUEST\\n------------------------------------\\n📅 Date: {{ $node[\"Webhook: Create Booking\"].json.body.date }}\\n⏰ Time: {{ $node[\"Webhook: Create Booking\"].json.body.time }}\\n👤 Client: {{ $node[\"Webhook: Create Booking\"].json.body.name }}\\n📞 Phone: {{ $node[\"Webhook: Create Booking\"].json.body.phone }}\\n💬 Telegram: @{{ $node[\"Webhook: Create Booking\"].json.body.telegram }}\\n\\n📍 Pickup: {{ $node[\"Webhook: Create Booking\"].json.body.pickup_address }}\\n🏁 Destination: {{ $node[\"Webhook: Create Booking\"].json.body.destination_address }}\\n\u00e2\u0084\u00b9\u00ef\u00b8\u008f Distance: {{ $node[\"Webhook: Create Booking\"].json.body.estimated_distance }} km\\n\u00f0\u009f\u0092\u00b5 Quoted Price: {{ $node[\"Webhook: Create Booking\"].json.body.price }} PLN\\n------------------------------------\\nRespond within 10 minutes!",
        "additionalFields": {
          "reply_markup": {
            "inline_keyboard": [
              [
                {
                  "text": "✅ Confirm",
                  "callback_data": "={{ \"confirm:\" + $node[\"Webhook: Create Booking\"].json.body.bookingId }}"
                },
                {
                  "text": "❌ Decline",
                  "callback_data": "={{ \"decline:\" + $node[\"Webhook: Create Booking\"].json.body.bookingId }}"
                }
              ],
              [
                {
                  "text": "➕ Counter-Offer (+20 PLN)",
                  "callback_data": "={{ \"counter:\" + $node[\"Webhook: Create Booking\"].json.body.bookingId + \":20\" }}"
                }
              ]
            ]
          }
        }
      },
      "id": "c1f8a2c3-4d5e-6f7a-8b9c-0d1e2f3a4b5c",
      "name": "Telegram: Alert Driver",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [
        820,
        240
      ]
