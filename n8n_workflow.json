      "typeVersion": 1,
      "position": [
        380,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "const callbackData = items[0].json.callback_query.data;\\nconst parts = callbackData.split(':');\\nconst action = parts[0];\\nconst bookingId = parts[1];\\nconst surcharge = parts[2] ? parseFloat(parts[2]) : 0;\\n\\nreturn [{\\n  json: {\\n    action,\\n    bookingId,\\n    surcharge,\\n    callbackQueryId: items[0].json.callback_query.id,\\n    messageId: items[0].json.callback_query.message.message_id\\n  }\\n}];"
      },
      "id": "2b3c4d5e-6f7a-8b9c-0d1e-2f3a4b5c6d7e",
      "name": "Parse Callback Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        600,
        500
      ]
    },
    {
      "parameters": {
