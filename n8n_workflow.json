    {
      "parameters": {
        "jsCode": "const callbackQuery = items[0].json.callback_query;\nif (callbackQuery) {\n  const parts = callbackQuery.data.split(':');\n  const action = parts[0];\n  const bookingId = parts[1];\n  const surcharge = parts[2] ? parseFloat(parts[2]) : 0;\n  return [{\n    json: {\n      type: \"callback\",\n      action,\n      bookingId,\n      surcharge,\n      callbackQueryId: callbackQuery.id,\n      messageId: callbackQuery.message.message_id,\n      chatId: callbackQuery.message.chat.id\n    }\n  }];\n} else if (items[0].json.message) {\n  return [{\n    json: {\n      type: \"message\",\n      text: items[0].json.message.text,\n      chatId: items[0].json.message.chat.id,\n      messageId: items[0].json.message.message_id\n    }\n  }];\n}\nreturn [];"
      },
