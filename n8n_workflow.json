    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH existing_user AS (\n  SELECT id, full_name, password_hash, phone FROM booking_users WHERE full_name = '{{ $json.body.fullName }}'\n),\nnew_user AS (\n  INSERT INTO booking_users (id, full_name, password_hash, phone)\n  SELECT '{{ $uuid }}', '{{ $json.body.fullName }}', '{{ $json.body.password }}', {{ $json.body.phone ? \"'\" + $json.body.phone + \"'\" : 'NULL' }}\n  WHERE NOT EXISTS (SELECT 1 FROM existing_user)\n  RETURNING id, full_name, password_hash, phone\n)\nSELECT id, full_name, password_hash, phone, 'registered' as action FROM new_user\nUNION ALL\nSELECT id, full_name, password_hash, phone, 'login' as action FROM existing_user;",
        "options": {}
      },
      "id": "7a8b064f-f784-44c0-addc-0bb37b02d616",
      "name": "SQL: Auth Router",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2176,
        4032
      ],
